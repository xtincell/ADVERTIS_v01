    status       String   @default("prospect") // prospect, contacted, confirmed, active

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([strategyId])
    @@index([type])
    @@index([market])
}

// M5 — Adaptations Multi-Marchés
model MarketAdaptation {
    id           String   @id @default(cuid())
    strategyId   String
    strategy     Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
