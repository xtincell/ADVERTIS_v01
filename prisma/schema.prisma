// ============================================
// LIVRABLES MANQUANTS — Architecture UPGRADERS
// Phase 5: T04, T06, M1-M3, M5, M7 + Checklist
// ============================================

// T04 — Big Idea Kit (per occasion)
model BigIdeaKit {
    id           String   @id @default(cuid())
    strategyId   String
    strategy     Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
    occasion     String   // e.g., "Rentrée Scolaire", "Fête des Mères", "Black Friday"
    insight      String?  @db.Text // Consumer insight driving this kit
    ideas        Json     // Array<{ title, concept, copy, visual, priority: P0|P1|P2, funnelStage }>
    funnelMapping Json?   // { awareness: [...ideaIds], consideration: [...], conversion: [...] }
    status       String   @default("draft") // draft, review, approved
    generatedBy  String   @default("manual") // manual, ai

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([strategyId])
    @@index([occasion])
}

// T06 — Stratégie Créative
model CreativeStrategy {
    id         String   @id @default(cuid())
    strategyId String   @unique
    strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
    content    Json     // { moodboard, keyVisual, graphicSystem, manifesto, copiesByChannel, tonalGuidelines }
    status     String   @default("draft") // draft, review, approved
    version    Int      @default(1)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// M1 — Budget Opérationnel 3 Couches
model OperationalBudget {
    id              String   @id @default(cuid())
    strategyId      String   @unique
    strategy        Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
    layer1Vision    Json     // { phases: [{ name, allocation, percentage }], totalBudget, decisionView }
    layer2Detail    Json     // { activations: [{ name, category, unitCost, quantity, subtotal, supplier }] }
    layer3Scenarios Json     // { P0: { items, total }, P1: { items, total }, P2: { items, total }, grandTotal }
    currency        String   @default("XAF")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// M2 — Chrono-Architecture (Gantt tasks)
model ChronoTask {
    id                     String    @id @default(cuid())
    strategyId             String
    strategy               Strategy  @relation(fields: [strategyId], references: [id], onDelete: Cascade)
    title                  String
    description            String?   @db.Text
    startDate              DateTime
    endDate                DateTime
    week                   Int       // Week number for Gantt positioning
    phase                  String    // "Préparation", "Lancement", "Activation", "Bilan"
    owner                  String?   // Responsible person/team
    status                 String    @default("pending") // pending, in_progress, done, blocked
    priority               String    @default("P1") // P0, P1, P2
    dependencies           Json?     // Array of ChronoTask IDs this depends on
    isValidationMilestone  Boolean   @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([strategyId])
    @@index([phase])
    @@index([week])
}

// M3 — Dossier Partenaires
model Partner {
    id           String   @id @default(cuid())
    strategyId   String
    strategy     Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
    name         String
    type         String   // INFLUENCER, TERRAIN, INSTITUTIONAL, MEDIA
