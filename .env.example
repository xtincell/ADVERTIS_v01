# ADVERTIS SaaS - Environment Variables
# Copy this file to .env and fill in the values

# ── Auth (required) ──
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Database ──
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/advertis_dev

# ── AI ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Google OAuth (optional — enables "Continuer avec Google" on login) ──
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Visual adapter API keys (optional — graceful degradation if not set) ──
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
PINTEREST_ACCESS_TOKEN=
ARENA_ACCESS_TOKEN=
